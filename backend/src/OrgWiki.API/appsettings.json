{
  "ConnectionStrings": {
    "OrgWiki": "Host=localhost;Port=5432;Database=orgwiki;Username=postgres;Password=postgres"
  },
  "OpenAI": {
    "Model": "gpt-5.6"
  },
  "Storage": {
    "Bucket": "orgwiki-documents"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Ingestion": {
    "MaxArchiveBytes": 10485760,
    "MaxSupportedDocuments": 10,
    "MaxIndividualFileBytes": 2097152,
    "MaxTotalExtractedBytes": 26214400,
    "MaxNormalizedCharactersPerDocument": 75000,
    "MaxTotalNormalizedCharacters": 300000,
    "MaxPdfPages": 50,
    "LocalStoragePath": "storage"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
